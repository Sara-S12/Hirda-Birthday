<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Happy 41st Birthday Hirda</title>
    <style>
      /* Page setup */
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        background: linear-gradient(135deg, #ffe4ec 0%, #fff5f7 45%, #fff1db 100%);
        overflow-x: hidden;
        color: #1e293b;
      }

      .page {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
      }

      /* Floating emoji background */
      .floating-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }

      .floating-emoji {
        position: absolute;
        font-size: 2rem;
        animation-name: bounce;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
      }

      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-18px);
        }
      }

      /* Main layout */
      .main {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
      }

      .container {
        width: 100%;
        max-width: 960px;
      }

      /* Main card */
      .card {
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 32px;
        padding: 32px;
        text-align: center;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.16);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        padding: 10px 16px;
        border-radius: 999px;
        background: #ffe4e6;
        color: #be123c;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .title {
        margin: 0 0 16px;
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        line-height: 1;
        font-weight: 900;
        color: #e11d48;
      }

      .intro {
        margin: 0 auto 32px;
        max-width: 760px;
        font-size: clamp(1.1rem, 2.5vw, 1.5rem);
        line-height: 1.6;
        color: #334155;
      }

      .highlights {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 40px;
      }

      .highlight-card {
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
      }

      .highlight-card h2 {
        margin: 0 0 8px;
        font-size: 1.05rem;
        color: #1f2937;
      }

      .highlight-card p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #475569;
      }

      .card-1 {
        background: linear-gradient(135deg, #fff1f2, #ffe4ec);
      }

      .card-2 {
        background: linear-gradient(135deg, #fff7ed, #fef3c7);
      }

      .card-3 {
        background: linear-gradient(135deg, #faf5ff, #fae8ff);
      }

      .emoji {
        display: block;
        margin-bottom: 8px;
        font-size: 2rem;
      }

      .quote-box {
        margin-bottom: 32px;
        padding: 24px;
        border-radius: 32px;
        background: #0f172a;
        color: white;
        box-shadow: 0 16px 30px rgba(15, 23, 42, 0.22);
      }

      .quote-box p {
        margin: 0;
        font-size: 1.15rem;
        line-height: 1.7;
        font-style: italic;
      }

      .cheer-button {
        display: inline-block;
        padding: 16px 32px;
        border-radius: 999px;
        background: #f43f5e;
        color: white;
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 700;
        box-shadow: 0 14px 24px rgba(244, 63, 94, 0.28);
        transition: transform 0.2s ease, background 0.2s ease;
      }

      .cheer-button:hover {
        transform: scale(1.05);
        background: #e11d48;
      }

      .footer-note {
        margin-top: 32px;
        font-size: 0.95rem;
        color: #64748b;
      }

      @media (max-width: 900px) {
        .highlights {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .main {
          padding: 32px 16px;
        }

        .card {
          padding: 24px;
          border-radius: 28px;
        }

        .floating-emoji {
          font-size: 1.6rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <!-- Decorative floating emoji background -->
      <div class="floating-layer" id="floatingLayer"></div>

      <!-- Main content -->
      <main class="main">
        <div class="container">
          <section class="card">
            <div class="badge">
              <span>🎁</span>
              <span>Made with love</span>
            </div>

            <h1 class="title">Happy 41st Birthday Hirda!</h1>

            <p class="intro">
              Wishing you a year filled with joy, laughter, happiness, and all the
              little moments like this campervan adventure that make life beautiful.
            </p>

            <div class="highlights">
              <div class="highlight-card card-1">
                <span class="emoji">🌟</span>
                <h2>Celebrate Big</h2>
                <p>Today is all about you and the amazing light you bring to others.</p>
              </div>

              <div class="highlight-card card-2">
                <span class="emoji">🎂</span>
                <h2>Make a Wish</h2>
                <p>May this next chapter be filled with exciting dreams coming true.</p>
              </div>

              <div class="highlight-card card-3">
                <span class="emoji">💛</span>
                <h2>So Appreciated</h2>
                <p>You deserve all the happiness and love that today can bring.</p>
              </div>
            </div>

            <div class="quote-box">
              <p>
                “Forty-one looks good on you — confident, kind, wise, and still full of sparkle.”
              </p>
            </div>

            <a
              class="cheer-button"
              href="https://www.youtube.com/watch?v=wz_6BXxI7xY&list=RDwz_6BXxI7xY&start_radio=1"
              target="_blank"
              rel="noreferrer"
            >
              Tap for a Birthday Cheer 🎊
            </a>

            <p class="footer-note">Crafted especially for a very special 41st birthday ✨</p>
          </section>
        </div>
      </main>
    </div>

    <script>
      // Emoji options used in the floating background.
      const balloons = ["🎈", "🎉", "✨", "🎂", "🥳", "💖"];

      // Create the decorative floating emoji elements.
      const floatingLayer = document.getElementById("floatingLayer");

      for (let i = 0; i < 24; i += 1) {
        const emoji = document.createElement("span");
        emoji.className = "floating-emoji";
        emoji.textContent = balloons[i % balloons.length];

        // Spread emojis across the page using simple maths.
        emoji.style.left = `${(i * 13) % 100}%`;
        emoji.style.top = `${(i * 17) % 100}%`;

        // Stagger animation timing so the motion feels playful and varied.
        emoji.style.animationDelay = `${(i % 7) * 0.25}s`;
        emoji.style.animationDuration = `${2 + (i % 4)}s`;

        floatingLayer.appendChild(emoji);
      }
    </script>
  </body>
</html>
